---
import '../styles/global.css';

const sshCommand = 'ssh edwinboon.dev';

const hints: { key: string; label: string }[] = [
  { key: 'j/k', label: 'navigate' },
  { key: 'enter', label: 'select' },
  { key: 'q', label: 'quit' },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edwin Boon · Terminal Portfolio</title>
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-gray-800 text-slate-200 font-mono min-h-dvh grid place-items-center p-6">
    <div class="border border-teal-border rounded-lg p-8 w-full max-w-lg flex flex-col gap-6">

      <div class="flex flex-col gap-1">
        <span class="text-xl font-bold text-accent">Edwin Boon</span>
        <span class="text-sm text-muted">Software Engineer · edwinboon.dev</span>
      </div>

      <p class="text-sm text-muted leading-relaxed">
        An interactive terminal portfolio.<br />
        Connect from your terminal — no installation required.
      </p>

      <div class="border border-teal-border rounded-md px-4 py-3 flex items-center justify-between gap-4 bg-gray-900">
        <div class="flex items-center text-[0.95rem]">
          <span class="text-accent font-bold">$</span>
          <span class="text-slate-200"> {sshCommand}</span>
          <span class="inline-block w-2 h-[1.1em] bg-accent-dim ml-0.5 align-middle animate-blink"></span>
        </div>
        <button
          id="copy-btn"
          data-copy={sshCommand}
          class="border border-teal-border rounded px-2 py-0.5 text-xs text-muted hover:text-accent hover:border-accent transition-colors cursor-pointer"
        >
          copy
        </button>
      </div>

      <div class="flex gap-5 text-xs text-muted flex-wrap">
        {hints.map(({ key, label }) => (
          <span><kbd class="text-accent-dim not-italic">{key}</kbd> {label}</span>
        ))}
      </div>

    </div>

    <script>
      const btn = document.getElementById('copy-btn') as HTMLButtonElement;

      btn.addEventListener('click', () => {
        const text = btn.dataset.copy!;
        navigator.clipboard.writeText(text);
        btn.textContent = 'copied!';
        btn.classList.add('text-accent', 'border-accent');
        setTimeout(() => {
          btn.textContent = 'copy';
          btn.classList.remove('text-accent', 'border-accent');
        }, 2000);
      });
    </script>
  </body>
</html>
